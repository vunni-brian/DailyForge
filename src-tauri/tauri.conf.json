{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DailyForge",
  "version": "0.1.0",
  "identifier": "com.vunnibrian.dailyforge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "npm run build"
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:dailyforge.db"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DailyForge",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
